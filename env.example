TELEGRAM_MODE=webhook
PORT=10000
LOG_LEVEL=INFO

APP_BASE_URL=https://your-service.onrender.com

# Active tenant for local polling fallback (must exist in company_profiles.json)
COMPANY_ID=hons

# Legacy bootstrap: copied into tenants table on startup via admin_upsert_tenant.py --bootstrap-env
# Prefer storing credentials in the tenants DB table for multi-tenant production.
TELEGRAM_BOT_TOKEN=__INSERT_TELEGRAM_BOT_TOKEN__
TELEGRAM_BOT_USERNAME=__INSERT_TELEGRAM_BOT_USERNAME__
TELEGRAM_WEBHOOK_SECRET=__INSERT_RANDOM_SECRET__

# Facebook Messenger (stored in tenants table; env used for bootstrap only)
FB_PAGE_ID=__INSERT_FB_PAGE_ID__
FB_ACCESS_TOKEN=__INSERT_FB_PAGE_ACCESS_TOKEN__
FB_VERIFY_TOKEN=__INSERT_FB_WEBHOOK_VERIFY_TOKEN__
FB_GRAPH_API_VERSION=v21.0

# Optional override path to tenant business profile store (defaults to ./company_profiles.json)
# COMPANY_PROFILES_FILE=/path/to/company_profiles.json

OPENAI_API_KEY=__INSERT_OPENAI_API_KEY__
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_TEMPERATURE=0.3
OPENAI_STORE=false

ENABLE_GEMINI_FALLBACK=false
GEMINI_API_KEY=__INSERT_GEMINI_API_KEY_IF_USED__
GEMINI_MODEL=gemini-2.5-flash

DATABASE_URL=sqlite:///./data/vyapar.db

RATE_LIMIT_COUNT=12
RATE_LIMIT_WINDOW_SECONDS=60
ALLOWED_CORS_ORIGINS=

# Lead qualification (Phase 2)
LEAD_ACTIVE_DAYS=30

# Product catalog prompt limits (DB-backed catalog)
CATALOG_FULL_LIST_LIMIT=8
CATALOG_PROMPT_SAMPLE_LIMIT=8

# Dashboard product CRUD (optional — leave empty to disable auth in dev)
DASHBOARD_API_KEY=__INSERT_DASHBOARD_API_KEY__

# Admin alerts (Phase 2: log-only placeholder when enabled)
ADMIN_ALERT_ENABLED=false
ADMIN_TELEGRAM_CHAT_ID=
ADMIN_ALERT_MIN_SCORE=80
ADMIN_ALERT_STAGES=hot,qualified
